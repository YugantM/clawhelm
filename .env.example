PROVIDER_BASE_URL=https://api.openai.com
PROVIDER_API_KEY=
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_BASE_URL=http://localhost:5173

ENABLE_OPENROUTER=true
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=your_openrouter_key

ALLOW_OPENAI_ROUTING=true
ALLOW_OPENROUTER_ROUTING=true

OPENCLAW_MODELS=meta-llama/llama-3.3-8b-instruct:free,google/gemma-2-9b-it:free

# OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/auth/github/callback

# JWT Configuration
JWT_SECRET_KEY=dev-secret-key-change-in-production

# Development Mode (enables /auth/dev/login for testing without OAuth credentials)
DEV_MODE=true
